#!/usr/bin/env node
import { fileURLToPath } from 'node:url';
import path from 'node:path';
import { runOnboard } from '../cli/onboard.js';
import { runReindex } from '../cli/reindex.js';
import { invoke, resolveProviderConfig, SUPPORTED_PROVIDERS } from '../server/providers.js';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const repoRoot = path.resolve(__dirname, '..');

const argv = process.argv.slice(2);

function printUsage() {
  process.stdout.write(`Usage: project-wiki <command> [args]

Commands:
  onboard <owner>/<repo> [flags]
      Scaffold seed pages under content/repos/<owner>-<repo>/, register the
      repo in .wiki-config.json, and push the redirect stub to
      <owner>/<repo>.wiki.git.

      Flags:
        --dry-run        Plan only; write no files, make no commits, push nothing.
        --scaffold-only  Run scaffold + config update; skip the wiki stub step.
        --stub-only      Run the wiki stub step only; skip scaffold + config update.

  reindex <owner>/<repo>... | --all [--dry-run]
      Re-run the scaffolder for one or more already-onboarded repos.
      Equivalent to running \`onboard --scaffold-only\` per repo. Repos must
      already be present in .wiki-config.json allowlist. Use --all to iterate
      every entry.

  test-provider <provider>
      Invoke the shared provider abstraction with a fixed prompt and print the
      model output. Supported providers: ${SUPPORTED_PROVIDERS.join(', ')}.

  help
      Print this message.

Environment:
  PROJECT_WIKI_AGENT_PROVIDER       Default CLI provider for agent surfaces.
  PROJECT_WIKI_GENERATOR_PROVIDER   Generator/scaffolder provider override.
  PROJECT_WIKI_GENERATOR_MODEL      Generator/scaffolder model override.
  PROJECT_WIKI_REVIEWER_PROVIDER    Reviewer provider override.
  PROJECT_WIKI_REVIEWER_MODEL       Reviewer model override.
  PROJECT_WIKI_BULK_PROVIDER        Bulk provider override.
  PROJECT_WIKI_SCAFFOLDER_PROVIDER  Legacy alias for generator provider.
  PROJECT_WIKI_SCAFFOLDER_MODEL     Legacy alias for generator model.
  PROJECT_WIKI_SCAFFOLDER_CWD       Directory the scaffolder runs in
                                    (default: source repo for <owner>/<repo>
                                    resolved at $HOME/<repo>, else this repo).
`);
}

async function main() {
  const cmd = argv[0];
  if (!cmd || cmd === 'help' || cmd === '--help' || cmd === '-h') {
    printUsage();
    return 0;
  }
  if (cmd === 'test-provider') {
    const provider = argv[1];
    if (!SUPPORTED_PROVIDERS.includes(provider)) {
      process.stderr.write(
        `project-wiki test-provider: provider must be one of ${SUPPORTED_PROVIDERS.join(', ')}\n`,
      );
      return 2;
    }
    try {
      const agentConfig = resolveProviderConfig('agent', process.env);
      const result = await invoke({
        provider,
        model: agentConfig.model,
        prompt: 'Reply with a short hello from the selected provider.',
        systemPrompt:
          'You are the project-wiki provider smoke test. Respond with one short plain-text line.',
        promptMode: 'inline',
        cwd: repoRoot,
        env: process.env,
        logger: console,
        purpose: 'test-provider',
      });
      process.stdout.write(result.stdout.trimEnd() + '\n');
      return 0;
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      process.stderr.write(`project-wiki test-provider: ${msg}\n`);
      return 1;
    }
  }
  if (cmd === 'reindex') {
    const rest = argv.slice(1);
    const flags = { dryRun: false };
    let all = false;
    const targets = [];
    for (const arg of rest) {
      if (arg === '--dry-run') flags.dryRun = true;
      else if (arg === '--all') all = true;
      else if (arg.startsWith('--')) {
        process.stderr.write(`project-wiki reindex: unknown flag "${arg}"\n`);
        return 2;
      } else targets.push(arg);
    }
    for (const t of targets) {
      if (!/^([^\/\s]+)\/([^\/\s]+)$/.test(t)) {
        process.stderr.write(`project-wiki reindex: target "${t}" must be <owner>/<repo>\n`);
        return 2;
      }
    }
    try {
      await runReindex({
        targets,
        all,
        flags,
        repoRoot,
        stdout: process.stdout,
        stderr: process.stderr,
        env: process.env,
      });
      return 0;
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      process.stderr.write(`project-wiki reindex: ${msg}\n`);
      if (process.env.PROJECT_WIKI_DEBUG && err instanceof Error && err.stack) {
        process.stderr.write(err.stack + '\n');
      }
      return 1;
    }
  }
  if (cmd !== 'onboard') {
    process.stderr.write(`project-wiki: unknown command "${cmd}"\n\n`);
    printUsage();
    return 2;
  }

  const rest = argv.slice(1);
  const flags = {
    dryRun: false,
    scaffoldOnly: false,
    stubOnly: false,
  };
  const positional = [];
  for (const arg of rest) {
    if (arg === '--dry-run') flags.dryRun = true;
    else if (arg === '--scaffold-only') flags.scaffoldOnly = true;
    else if (arg === '--stub-only') flags.stubOnly = true;
    else if (arg.startsWith('--')) {
      process.stderr.write(`project-wiki onboard: unknown flag "${arg}"\n`);
      return 2;
    } else positional.push(arg);
  }
  if (positional.length !== 1) {
    process.stderr.write(
      'project-wiki onboard: expected exactly one <owner>/<repo> argument\n',
    );
    return 2;
  }
  if (flags.scaffoldOnly && flags.stubOnly) {
    process.stderr.write(
      'project-wiki onboard: --scaffold-only and --stub-only are mutually exclusive\n',
    );
    return 2;
  }

  const target = positional[0];
  const match = /^([^\/\s]+)\/([^\/\s]+)$/.exec(target);
  if (!match) {
    process.stderr.write(
      `project-wiki onboard: target "${target}" must be <owner>/<repo>\n`,
    );
    return 2;
  }

  try {
    await runOnboard({
      owner: match[1],
      repo: match[2],
      flags,
      repoRoot,
      stdout: process.stdout,
      stderr: process.stderr,
      env: process.env,
    });
    return 0;
  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err);
    process.stderr.write(`project-wiki onboard: ${msg}\n`);
    if (process.env.PROJECT_WIKI_DEBUG && err instanceof Error && err.stack) {
      process.stderr.write(err.stack + '\n');
    }
    return 1;
  }
}

main().then((code) => {
  process.exit(code);
});
