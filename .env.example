# Port the auth-gated front-server binds to.
PORT=4321

# Base URL of the Pay service that mints/validates auth tokens.
# Used by @jeffrey-keyser/pay-auth-integration to call ${PAY_AUTH_BASE_URL}/auth/ping
# when validating Bearer tokens / session tokens.
PAY_AUTH_BASE_URL=https://pay.example.com

# URL that unauthenticated users are 302-redirected to. The originally requested
# URL is appended as the `returnUrl` query parameter.
# Defaults to `${PAY_AUTH_BASE_URL}/login` when unset.
PAY_AUTH_LOGIN_URL=https://pay.example.com/login

# Name of the cookie that carries the Pay session token, when the user is
# authenticated via a browser session rather than an Authorization: Bearer
# header. Matches the client-side token storage key (`accessToken`) by default.
PAY_AUTH_COOKIE_NAME=accessToken

# Name of the query-string parameter appended to PAY_AUTH_LOGIN_URL that
# carries the original URL. Pay's login UI reads this to redirect back after
# successful sign-in.
PAY_AUTH_RETURN_URL_PARAM=returnUrl

# Verbose auth logging (true|false).
PAY_AUTH_DEBUG=false

# Canonical public origin (scheme + host) used to build the post-login
# returnUrl. REQUIRED. The server refuses to start if this is unset. A
# configured value is the only safe anchor for the returnUrl: request
# headers (Host, X-Forwarded-Proto) are attacker-controlled, and a
# path-only returnUrl would resolve against the Pay service's own
# origin rather than this app. Must be http:// or https://.
# Example: https://wiki.jeffreykeyser.net
PUBLIC_ORIGIN=https://wiki.example.com

# Express `trust proxy` setting. Leave blank (default off) when this server
# is reached directly. Set explicitly only when running behind a known
# reverse proxy whose X-Forwarded-* headers you trust.
# Accepted values: "true" / "false", a hop count (e.g. "1"), an IP / CIDR
# list (e.g. "127.0.0.1, 10.0.0.0/8"), or a named preset ("loopback",
# "linklocal", "uniquelocal"). See Express docs for details.
TRUST_PROXY=

# RabbitMQ connection URL for the standalone wiki updater consumer.
# Defaults to amqp://localhost:5672 when unset.
RABBITMQ_URL=amqp://localhost:5672
